modules = ["python-3.11"]

[nix]
channel = "stable-24_05"

[deployment]
run = ["python3", "main.py"]
deploymentTarget = "cloudrun"

[workflows]
runButton = "Run"

[[workflows.workflow]]
name = "Run"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "git config core.hooksPath .githooks && python3 main.py"

[gitHubImport]
requiredFiles = [".replit", "main.py"]

[git]
disableAutoCommit = true
